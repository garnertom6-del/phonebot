# Database
# Local demo (default): SQLite file, no external services needed.
DATABASE_URL="file:./dev.db"
# Production (Supabase/PostgreSQL): switch provider to "postgresql" in
# prisma/schema.prisma and use your Supabase connection string:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# App
SESSION_SECRET="change-me-to-a-long-random-string"
APP_BASE_URL="http://localhost:3000"
CLIENT_LINK_EXPIRY_DAYS="7"
# Optional generic, non-PHI MP3/M4A explaining client rights and the intake.
# The same player appears before the intake and again before signing.
NEXT_PUBLIC_INTAKE_ORIENTATION_AUDIO_URL=""

# DocuSign (optional - app works without these)
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_USER_ID=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_PRIVATE_KEY=""
DOCUSIGN_BASE_PATH="https://demo.docusign.net/restapi"
DOCUSIGN_REDIRECT_URI=""

# Email/SMS (optional - console logging is used when empty)
SENDGRID_API_KEY=""
EMAIL_FROM="intake@mooredivinecare.example"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# NC Tracks lookup (optional - requires your approved portal/API adapter)
NC_TRACKS_LOOKUP_URL=""
NC_TRACKS_LOOKUP_SECRET=""

# Admin password
# Set this in production to replace the demo password on the next deploy.
ADMIN_PASSWORD=""
