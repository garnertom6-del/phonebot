// Moore Divine Care Smart Intake - Prisma schema.
// Local demo uses SQLite (default). For production with Supabase/PostgreSQL,
// change provider to "postgresql" and set DATABASE_URL (see README_DEPLOYMENT.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         String     @default("staff") // staff | admin | reviewer
  createdAt    DateTime   @default(now())
  auditLogs    AuditLog[]
}

model Client {
  id            String   @id @default(uuid())
  fullName      String
  dob           String
  midNumber     String?
  recordNumber  String?
  email         String?
  phone         String?
  guardianName  String?
  guardianEmail String?
  guardianPhone String?
  createdAt     DateTime @default(now())
  intakes       Intake[]
}

model Intake {
  id             String    @id @default(uuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id])
  packageName    String    @default("Moore Divine Care Client Intake Package")
  status         String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | SUBMITTED | NEEDS_REVIEW | SIGNED | COMPLETED
  mode           String    @default("full") // fast | full
  expectCca      Boolean   @default(true) // short client intake; clinician CCA fills the rest
  token          String    @unique
  tokenExpiresAt DateTime
  intakeDate     String?
  location       String?
  linkSentAt     DateTime?
  lastActivityAt DateTime?
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  answers            IntakeAnswer[]
  sections           IntakeSection[]
  signatures         Signature[]
  generatedPdfs      GeneratedPdf[]
  auditLogs          AuditLog[]
  uploadedDocuments  UploadedDocument[]
  releaseConsents    ReleaseConsent[]
  referrals          Referral[]
  emergencyContacts  EmergencyContact[]
  medications        Medication[]
  substanceUseRows   SubstanceUseRow[]
  treatmentPlanRows  TreatmentPlanSignatureRow[]
}

model IntakeAnswer {
  id       String @id @default(uuid())
  intakeId String
  intake   Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  key      String
  value    String // JSON-encoded value (string | string[] | boolean | number)
  updatedAt DateTime @updatedAt

  @@unique([intakeId, key])
  @@index([intakeId])
}

model IntakeSection {
  id        String    @id @default(uuid())
  intakeId  String
  intake    Intake    @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  sectionKey String
  status    String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED
  startedAt DateTime?
  completedAt DateTime?

  @@unique([intakeId, sectionKey])
}

model Signature {
  id           String   @id @default(uuid())
  intakeId     String
  intake       Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  role         String // client | guardian | staff | clinician | witness | medicalDirector
  imageData    String // PNG data URL from the signature canvas
  printedName  String
  relationship String? // client | parent | guardian | legalRepresentative
  signedDate   String
  createdAt    DateTime @default(now())

  @@unique([intakeId, role])
}

model PdfTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  filePath  String
  pageCount Int
  createdAt DateTime @default(now())
  fieldMappings PdfFieldMapping[]
}

// Admin mapping-screen overrides; merged over src/config/mooreDivinePacketMap.json
model PdfFieldMapping {
  id         String      @id @default(uuid())
  templateId String
  template   PdfTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey   String
  page       Int
  data       String // JSON: {source,type,x,y,width,height,fontSize,lines,required,role,consentKey,notes,deleted?}
  updatedAt  DateTime    @updatedAt

  @@unique([templateId, fieldKey])
}

model GeneratedPdf {
  id        String   @id @default(uuid())
  intakeId  String
  intake    Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  filePath  String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  intakeId  String?
  intake    Intake?  @relation(fields: [intakeId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     String // intake_created | link_opened | section_started | section_completed | signature_captured | packet_submitted | staff_reviewed | pdf_generated | pdf_downloaded | ...
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([intakeId])
}

model UploadedDocument {
  id        String   @id @default(uuid())
  intakeId  String
  intake    Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  docType   String // birth_certificate | insurance_card | court_order | ss_card | iep_records | medication_list | pcp_plan | immunization_records | standing_orders | other
  fileName  String
  filePath  String
  mimeType  String
  createdAt DateTime @default(now())
}

model ReleaseConsent {
  id        String  @id @default(uuid())
  intakeId  String
  intake    Intake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  slot      Int // 1..3 map to packet pages 19-21; >3 duplicates page template
  recipient String
  items     String // JSON string[]
  purpose   String?
  thruDate  String?
  agreed    Boolean @default(false)
}

model Referral {
  id       String @id @default(uuid())
  intakeId String
  intake   Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  slot     Int
  name     String
  phone    String?
}

model EmergencyContact {
  id        String  @id @default(uuid())
  intakeId  String
  intake    Intake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  slot      Int // 1 or 2
  name      String
  street    String?
  city      String?
  state     String?
  homePhone String?
  workPhone String?
  cellPhone String?
}

model Medication {
  id       String  @id @default(uuid())
  intakeId String
  intake   Intake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  name     String
  dosage   String?
  kind     String  @default("prescription") // prescription | otc
}

model SubstanceUseRow {
  id        String  @id @default(uuid())
  intakeId  String
  intake    Intake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  slot      Int // 1..5
  name      String
  ageFirst  String?
  frequency String?
  route     String?
  amount    String?
  lastUsed  String?
}

model TreatmentPlanSignatureRow {
  id         String  @id @default(uuid())
  intakeId   String
  intake     Intake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  slot       Int
  staffDate  String?
  clientDate String?
}
